# Frontend config (only PUBLIC values — never secrets).
#
# VITE_API_URL = the backend's base origin (no trailing /api, no trailing slash).
# - Leave EMPTY for local dev (Vite proxies /api to localhost:4000 via vite.config.ts).
# - Set to your deployed backend for production, e.g. https://chad-backend.onrender.com
#
# On Vercel, set this in: Project → Settings → Environment Variables.
VITE_API_URL=
